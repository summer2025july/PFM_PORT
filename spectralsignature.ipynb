import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import random



# Read the CSV file
red_target_spectrum = pd.read_csv(
    '/content/data/target_signature_pfm_1_svc.txt',  # Replace with your file path
    sep=r'\s+', 
    header=None,
    names=['Wavelength', 'Reflectance'],
    skiprows=1,
    engine='python'
)

# Clean data
red_target_spectrum_cleaned = red_target_spectrum.dropna(subset=['Reflectance'])
wavelengths = red_target_spectrum_cleaned['Wavelength'].values
reflectance_AP = red_target_spectrum_cleaned['Reflectance'].values

# --- Equation for AT mines reflectance ---
# Lower overall reflectance (scale factor), add wavelength-dependent attenuation,
# and small Gaussian noise to simulate soil/metal effects
reflectance_AT = (
    0.85 * reflectance_AP
    - 0.0005 * (wavelengths - wavelengths.min())  # attenuation slope
    + np.random.normal(0, 0.1, size=len(reflectance_AP))  # noise
)



print(reflectance_AT.shape)
# Print the first few rows
print(red_target_spectrum_cleaned[['Wavelength', 'Reflectance']].head())

# Print all rows (be careful if the file is large)
print(red_target_spectrum_cleaned[['Wavelength', 'Reflectance']])

# Plot both curves
plt.figure(figsize=(10,6))
plt.plot(red_target_spectrum_cleaned["Wavelength"], reflectance_AP, label="PFM-1 AP mines", color="blue")
plt.plot(red_target_spectrum_cleaned["Wavelength"], reflectance_AT, label="AT mines", color="red", linestyle="--")

plt.xlabel("Wavelength (nm)")
plt.ylabel("Reflectance (%)")
plt.title("Spectral Signature Comparison")
plt.legend()
plt.grid(True, linestyle="--", alpha=0.6)
plt.tight_layout()
plt.show()